# Supabase — get these from your Supabase project dashboard → Settings → API
# VITE_ prefix makes them available in the browser bundle (safe: anon key only)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic — get from console.anthropic.com → API Keys
# Server-side only (used in /api/* functions, never exposed to browser)
ANTHROPIC_API_KEY=sk-ant-...
